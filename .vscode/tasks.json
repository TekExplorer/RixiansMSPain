{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build HideDetailsMod (Debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build HideDetailsMod (Canary)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-p:WorkshopChannel=Canary"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Publish HideDetailsMod (Canary)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-c",
        "Release",
        "-p:WorkshopChannel=Canary"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Upload HideDetailsMod (Canary)",
      "type": "shell",
      "command": "cmd",
      "options": {
        "cwd": "${workspaceFolder}/workshop"
      },
      "args": [
        "/c",
        "call",
        "${workspaceFolder}/workshop/upload_to_workshop.bat",
        "Canary"
      ]
    },
    {
      "label": "Build HideDetailsMod (Production)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-p:WorkshopChannel=Production"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Publish HideDetailsMod (Production)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-c",
        "Release",
        "-p:WorkshopChannel=Production"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Upload HideDetailsMod (Production)",
      "type": "shell",
      "command": "cmd",
      "options": {
        "cwd": "${workspaceFolder}/workshop"
      },
      "args": [
        "/c",
        "call",
        "${workspaceFolder}/workshop/upload_to_workshop.bat",
        "Production"
      ]
    },

    {
      "label": "Credits: Validate",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/CreditsTool.ps1",
        "-Mode",
        "Validate"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "Credits: Fix",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/CreditsTool.ps1",
        "-Mode",
        "Fix"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "Credits: Add Missing Credits",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/CreditsTool.ps1",
        "-Mode",
        "Fix",
        "-AssetsOnly"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
