{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build HideDetailsMod (Production)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-p:WorkshopChannel=Production"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build HideDetailsMod (Beta)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-p:WorkshopChannel=Beta"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Publish HideDetailsMod (Production)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-c",
        "Release",
        "-p:WorkshopChannel=Production"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Publish HideDetailsMod (Beta)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/HideDetailsMod.csproj",
        "-c",
        "Release",
        "-p:WorkshopChannel=Beta"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Upload HideDetailsMod (Production)",
      "type": "shell",
      "command": "cmd",
      "options": {
        "cwd": "${workspaceFolder}/workshop"
      },
      "args": [
        "/c",
        "call",
        "${workspaceFolder}\\workshop\\upload_to_workshop.bat",
        "Production"
      ]
    },
    {
      "label": "Upload HideDetailsMod (Beta)",
      "type": "shell",
      "command": "cmd",
      "options": {
        "cwd": "${workspaceFolder}/workshop"
      },
      "args": [
        "/c",
        "call",
        "${workspaceFolder}\\workshop\\upload_to_workshop.bat",
        "Beta"
      ]
    }
  ]
}
